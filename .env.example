APP_NAME=PSVBot API
APP_VERSION=0.1.0
DEBUG=true
PORT=8001

API_BEARER_TOKEN=change-me
API_BEARER_SUBJECT=psvbot-service
API_BEARER_ROLE=service

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MONGO_URL=mongodb://localhost:27017
MONGO_DB=alphagraphics-multitenant

PRINTSMITH_HEADLESS=true
PRINTSMITH_TIMEOUT_SECONDS=300
PRINTSMITH_KEEP_BROWSER_OPEN=false
PRINTSMITH_DEBUG=true
PRINTSMITH_URL=https://your-company.printsmithvision.com/PrintSmith/PrintSmith.html
PRINTSMITH_USERNAME=psv-user
PRINTSMITH_PASSWORD=psv-password
PRINTSMITH_COMPANY=your-company

PRINTSMITH_QUOTE_SUMMARY_STORAGE_ROOT=estimates
BUCKET_NAME=psv_alpha_graphics
BUCKET_REGION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=
QUEUE_POLL_INTERVAL_SECONDS=60
QUEUE_IDLE_POLL_INTERVAL_SECONDS=10
QUEUE_BUSY_POLL_INTERVAL_SECONDS=60
MACHINE_NAME=
QUEUE_ENFORCE_MACHINE_ASSIGNMENT=true
BOT_LOG_LOCAL_DIR=logs
BOT_LOG_STORAGE_ROOT=logs
BOT_LOG_ARCHIVE_RUN_HOUR=0
BOT_LOG_ARCHIVE_RUN_MINUTE=10

MAIN_SERVER_API_BASE_URL=http://localhost:8000/api/v1
MAIN_SERVER_API_TOKEN=
