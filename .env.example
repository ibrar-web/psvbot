PRINTSMITH_QUOTE_SUMMARY_STORAGE_ROOT=storage/estimates
BOT_STORAGE_ROOT=storage

BUCKET_NAME=psv_alpha_graphics
BUCKET_REGION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=
